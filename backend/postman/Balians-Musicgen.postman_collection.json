    {
      "name": "Direct Suno API",
      "description": "Use these only when you want to call Suno directly from Postman. They do not go through the Balians backend.",
      "item": [
        {
          "name": "Suno Generate",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{providerApiKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"Write a Western Armenian song about resilience.\",\n  \"customMode\": true,\n  \"instrumental\": false,\n  \"model\": \"V4\",\n  \"style\": \"folk-pop\",\n  \"title\": \"Resilient Hearts\",\n  \"callBackUrl\": \"{{providerCallbackUrl}}\"\n}"
            },
            "url": {
              "raw": "{{providerBaseUrl}}/api/v1/generate",
              "host": [
                "{{providerBaseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "generate"
              ]
            }
          }
        },
        {
          "name": "Suno Record Info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{providerApiKey}}"
              }
            ],
            "url": {
              "raw": "{{providerBaseUrl}}/api/v1/generate/record-info?taskId={{providerTaskId}}",
              "host": [
                "{{providerBaseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "generate",
                "record-info"
              ],
              "query": [
                {
                  "key": "taskId",
                  "value": "{{providerTaskId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Suno Credits",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{providerApiKey}}"
              }
            ],
            "url": {
              "raw": "{{providerBaseUrl}}/api/v1/get-credits",
              "host": [
                "{{providerBaseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "get-credits"
              ]
            }
          }
        }
      ]
