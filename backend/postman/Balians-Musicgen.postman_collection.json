    {
      "name": "Prompt Templates",
      "item": [
        {
          "name": "Create Prompt Template",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"projectId\": \"{{projectId}}\",\n  \"name\": \"Daily Western Armenian Template\",\n  \"customMode\": true,\n  \"instrumental\": false,\n  \"model\": \"V4\",\n  \"promptTemplate\": \"Write a Western Armenian song about hope and homeland.\",\n  \"styleTemplate\": \"folk-pop\",\n  \"titleTemplate\": \"Daily Armenian Song\",\n  \"active\": true,\n  \"isDefault\": false\n}"
            },
            "url": {
              "raw": "{{backendBaseUrl}}/api/v1/prompt-templates",
              "host": [
                "{{backendBaseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "prompt-templates"
              ]
            }
          }
        },
        {
          "name": "List Prompt Templates",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{backendBaseUrl}}/api/v1/prompt-templates?projectId={{projectId}}&activeOnly=true",
              "host": [
                "{{backendBaseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "prompt-templates"
              ],
              "query": [
                {
                  "key": "projectId",
                  "value": "{{projectId}}"
                },
                {
                  "key": "activeOnly",
                  "value": "true"
                }
              ]
            }
          }
        },
        {
          "name": "Get Prompt Template",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{backendBaseUrl}}/api/v1/prompt-templates/{{templateId}}",
              "host": [
                "{{backendBaseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "prompt-templates",
                "{{templateId}}"
              ]
            }
          }
        }
      ]
    },
