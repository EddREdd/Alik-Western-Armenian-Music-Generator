    {
      "name": "Suno Callback Testing",
      "item": [
        {
          "name": "Send Complete Callback To Backend",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": 200,\n  \"msg\": \"ok\",\n  \"data\": {\n    \"callbackType\": \"complete\",\n    \"task_id\": \"{{providerTaskId}}\",\n    \"data\": [\n      {\n        \"id\": \"track-001\",\n        \"audio_url\": \"https://cdn.example.com/audio-001.mp3\",\n        \"stream_audio_url\": \"https://cdn.example.com/audio-001-stream.mp3\",\n        \"image_url\": \"https://cdn.example.com/image-001.jpg\",\n        \"prompt\": \"Write a Western Armenian song about resilience.\",\n        \"model_name\": \"V4\",\n        \"title\": \"Resilient Hearts\",\n        \"tags\": \"folk-pop,western-armenian\",\n        \"createTime\": \"2026-03-10T12:00:00Z\",\n        \"duration\": 132\n      }\n    ]\n  }\n}"
            },
            "url": {
              "raw": "{{backendBaseUrl}}/api/v1/integrations/suno/callback",
              "host": [
                "{{backendBaseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "integrations",
                "suno",
                "callback"
              ]
            }
          }
        }
      ]
    },
